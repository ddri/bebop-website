---
import { FolderPlus, PenLine, Rocket } from 'lucide-astro';

const steps = [
  {
    number: "1",
    icon: FolderPlus,
    title: "Create a campaign",
    description: "Group your content around a theme, launch, or strategy. Campaigns keep everything organized.",
  },
  {
    number: "2",
    icon: PenLine,
    title: "Write and collaborate",
    description: "Draft in a real-time editor. Your team sees changes as they happen — with live cursors and presence.",
  },
  {
    number: "3",
    icon: Rocket,
    title: "Schedule and publish",
    description: "Pick your platforms and times. Bebop handles the rest — with automatic retries and monitoring.",
  },
];
---

<section id="how-it-works" class="w-full py-20 bg-white">
  <div class="container mx-auto">
    <h2 class="text-3xl font-bold text-center mb-12">How it works.</h2>
    <div class="flex flex-wrap justify-center gap-8">
      {steps.map((step) => (
        <div class="flex flex-col items-center text-center w-full md:w-1/3 lg:w-1/4 px-4">
          <div class="w-12 h-12 rounded-full bg-pink text-dark-grey flex items-center justify-center font-bold text-lg mb-4">
            {step.number}
          </div>
          <div class="mb-3">
            <step.icon class="h-8 w-8 text-primary" />
          </div>
          <h3 class="text-xl font-semibold mb-2">{step.title}</h3>
          <p class="text-gray-600 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
