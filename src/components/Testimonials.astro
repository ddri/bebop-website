---
const testimonials = [
  {
    quote: "Managing a content campaign across Hashnode, Dev.to, and Bluesky used to mean juggling three tabs and hoping nothing fell through the cracks. Bebop makes it one workflow.",
    author: "Sarah Choo",
    role: "Open Source Contributor",
  },
  {
    quote: "Finally a platform that thinks in campaigns, not just posts. The scheduling and multi-platform publishing have changed how our team plans content launches.",
    author: "Liam Miller",
    role: "Content Strategist",
  },
];
---

<section id="testimonials" class="w-full py-20 bg-white">
  <div class="container mx-auto">
    <h2 class="text-3xl font-bold text-center mb-12">Community Feedback</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {testimonials.map((testimonial) => (
        <div class="bg-gray-50 p-6 rounded-lg shadow-md">
          <p class="text-lg mb-4 leading-relaxed italic">"{testimonial.quote}"</p>
          <div class="flex items-center">
            <div class="w-10 h-10 rounded-full bg-pink text-white flex items-center justify-center font-serif font-bold text-sm mr-4">{testimonial.author.charAt(0)}</div>
            <div>
              <p class="font-semibold">{testimonial.author}</p>
              <p class="text-sm text-gray-600">{testimonial.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
