---
import { Newspaper, Send, Users, Calendar } from 'lucide-astro';

const features = [
  {
    icon: Newspaper,
    title: "Campaign-First",
    description: "Organize content into campaigns. Plan, draft, schedule, and publish as a coordinated effort — not scattered posts.",
  },
  {
    icon: Send,
    title: "Publish Everywhere",
    description: "Hashnode, Dev.to, Bluesky, Mastodon, and more. Write once, adapt automatically, publish from one place.",
  },
  {
    icon: Users,
    title: "Real-Time Collaboration",
    description: "Work together with live cursors and presence. Role-based access keeps your team organized.",
  },
  {
    icon: Calendar,
    title: "Smart Scheduling",
    description: "Set it and forget it. Automatic publishing with retry logic, queue monitoring, and detailed history.",
  },
];
---

<section id="features" class="w-full py-20 bg-[hsl(348,30%,95%)]">
  <div class="container mx-auto">
    <h2 class="text-3xl font-bold text-center mb-12">Everything you need to publish.</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {features.map((feature) => (
        <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-pink">
          <div class="mb-4">
            <feature.icon class="h-10 w-10 text-primary" />
          </div>
          <h3 class="text-xl font-semibold mb-2">{feature.title}</h3>
          <p class="text-gray-600">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
