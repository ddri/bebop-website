---
import Analytics from '@vercel/analytics/astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Bebop is an opinionated and open source CMS built for content campaigns. Write once, publish everywhere, and track everything." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lora:wght@400;500;700&display=swap" rel="stylesheet" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <Analytics />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  html {
    font-family: system-ui, sans-serif;
  }

  body {
    margin: 0;
    padding: 0;
  }
</style>
