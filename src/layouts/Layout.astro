---
import Analytics from '@vercel/analytics/astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Bebop is a content marketing platform for creators and teams. Create campaigns, collaborate in real time, and publish everywhere." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/lora-latin.woff2" as="font" type="font/woff2" crossorigin />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <Analytics />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  html {
    font-family: system-ui, sans-serif;
  }

  body {
    margin: 0;
    padding: 0;
  }
</style>
